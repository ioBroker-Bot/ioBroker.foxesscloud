{
    "i18n": true,
    "type": "tabs",
    "items": {
        "_general": {
            "type": "panel",
            "label": "tab_general",
            "icon": "data:image/svg+xml;base64,",
            "items": {
                "_apiHeader": {
                    "type": "header",
                    "text": "FoxESS Cloud API Configuration",
                    "size": 3
                },
                "token": {
                    "type": "password",
                    "label": "API Token",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "help": "API-Key aus der FoxESS Cloud"
                },
                "sn": {
                    "type": "text",
                    "label": "Serial Number (SN)",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "help": "Seriennummer vom Inverter"
                },
                "interval": {
                    "type": "number",
                    "label": "Update Interval (seconds)",
                    "min": 60,
                    "max": 3600,
                    "default": 60,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "help": "Aktualisierungsintervall in Sekunden (Empfohlen: 60, Minimum: 60, API-Limit: 1440 Calls/Tag)"
                },
                "_infoBox1": {
                    "type": "staticText",
                    "text": "instance_info_text",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "style": {
                        "fontSize": "0.875rem",
                        "whiteSpace": "pre-wrap",
                        "marginTop": "20px",
                        "padding": "10px 14px",
                        "border": "1px solid #546e7a",
                        "borderRadius": "6px",
                        "backgroundColor": "rgba(84, 110, 122, 0.12)"
                    }
                }
            }
        },
        "_pvPowerJSON": {
            "type": "panel",
            "label": "tab_statistics",
            "icon": "data:image/svg+xml;base64,",
            "items": {
                "_statisticsHeader": {
                    "type": "header",
                    "text": "PV Power Energy Statistics (JSON)",
                    "size": 3
                },
                "enablePvPowerJSON": {
                    "type": "checkbox",
                    "label": "Enable PV Power JSON generation",
                    "default": false,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "help": "Generate JSON tables for daily (current week), weekly (current month), and monthly (current year) PV power data for VIS widgets"
                },
                "_dataOptions": {
                    "type": "header",
                    "text": "Data Collection Options",
                    "size": 4
                },
                "pvPowerJSON_daily": {
                    "type": "checkbox",
                    "label": "Daily statistics",
                    "default": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "help": "Generate daily energy data for the current week (Monday to Sunday)"
                },
                "pvPowerJSON_weekly": {
                    "type": "checkbox",
                    "label": "Weekly statistics",
                    "default": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "help": "Generate weekly energy data for the current month (all weeks in this month)"
                },
                "pvPowerJSON_monthly": {
                    "type": "checkbox",
                    "label": "Monthly statistics",
                    "default": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "help": "Generate monthly energy data for the current year (all 12 months)"
                },
                "_costSettings": {
                    "type": "header",
                    "text": "Cost Calculation (Optional)",
                    "size": 4
                },
                "kwhPrice": {
                    "type": "number",
                    "label": "Price per kWh (€ - optional)",
                    "min": 0,
                    "step": 0.01,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "help": "Optional: Enter price per kWh for cost calculations. Leave empty or 0 to disable price display"
                },
                "_startValues": {
                    "type": "header",
                    "text": "Initial Start Values (one-time only)",
                    "size": 4
                },
                "pvPowerJSONStartDaily": {
                    "type": "number",
                    "label": "Daily start value (kWh)",
                    "min": 0,
                    "step": 0.001,
                    "xs": 12,
                    "sm": 12,
                    "md": 4,
                    "lg": 4,
                    "xl": 4,
                    "help": "start_value_daily_help"
                },
                "pvPowerJSONStartWeekly": {
                    "type": "number",
                    "label": "Weekly start value (kWh)",
                    "min": 0,
                    "step": 0.001,
                    "xs": 12,
                    "sm": 12,
                    "md": 4,
                    "lg": 4,
                    "xl": 4,
                    "help": "start_value_weekly_help"
                },
                "pvPowerJSONStartMonthly": {
                    "type": "number",
                    "label": "Monthly start value (kWh)",
                    "min": 0,
                    "step": 0.001,
                    "xs": 12,
                    "sm": 12,
                    "md": 4,
                    "lg": 4,
                    "xl": 4,
                    "help": "start_value_monthly_help"
                },
                "_infoBox2": {
                    "type": "staticText",
                    "text": "extended_statistics_info_text",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "style": {
                        "fontSize": "0.875rem",
                        "whiteSpace": "pre-wrap",
                        "marginTop": "20px",
                        "padding": "10px 14px",
                        "border": "1px solid #546e7a",
                        "borderRadius": "6px",
                        "backgroundColor": "rgba(84, 110, 122, 0.12)"
                    }
                }
            }
        },
        "_reporting": {
            "type": "panel",
            "label": "tab_reporting",
            "icon": "data:image/svg+xml;base64,",
            "items": {
                "_reportingHeader": {
                    "type": "header",
                    "text": "Energy Reporting",
                    "size": 3
                },
                "enableReporting": {
                    "type": "checkbox",
                    "label": "Enable energy reporting",
                    "default": false,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "help": "enable_reporting_help"
                },
                "_infoBox3": {
                    "type": "staticText",
                    "text": "reporting_info_text",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "style": {
                        "fontSize": "0.875rem",
                        "whiteSpace": "pre-wrap",
                        "marginTop": "20px",
                        "padding": "10px 14px",
                        "border": "1px solid #546e7a",
                        "borderRadius": "6px",
                        "backgroundColor": "rgba(84, 110, 122, 0.12)"
                    }
                }
            }
        }
    }
}